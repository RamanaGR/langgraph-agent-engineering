# Application
APP_ENV=development
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+asyncpg://talentscreen:talentscreen@localhost:5432/talentscreen

# Redis (ARQ queue + query cache)
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=talentscreen-docs
MINIO_SECURE=false

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=talentscreen_chunks

# Embeddings (ollama = nomic-embed-text locally; local = sentence-transformers)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIMENSION=768

# LLM (ollama | anthropic | groq | bedrock)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Recommended from your machine: llama3.2:latest (fast instruct) or qwen2.5-coder:7b (JSON/tools)
OLLAMA_MODEL=llama3.2:latest

# Optional cloud fallbacks (dev escape hatch)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# AWS Bedrock stub (typed interface; not called without credentials)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Langfuse (optional Week 1 wiring)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=64
DEFAULT_TENANT_ID=demo-tenant

# Retrieval / RAG (Week 2)
RETRIEVAL_TOP_K=20
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QUERY_CACHE_TTL_SECONDS=3600

# Phase 1b — hybrid + semantic cache
RETRIEVAL_MODE=hybrid
RRF_K=60
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=86400

# Phase 2a — LangGraph agents
AGENT_CHECKPOINTER=memory
SUMMARIZATION_MESSAGE_THRESHOLD=10

# Phase 3 — React UI auth + CORS
AUTH_ENABLED=false
API_KEY_RECRUITER=recruiter-dev-key
API_KEY_CANDIDATE=candidate-dev-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
